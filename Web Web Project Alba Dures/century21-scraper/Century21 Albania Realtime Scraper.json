    {
      "parameters": {
        "jsCode": "// 1. Зчитуємо текст sitemap XML з попередньої ноди (Merge)\nconst sitemap = $json.data || $json.body || $input.first().json.data || \"\";\n\n// 2. Зчитуємо вже існуючі URL з Get Existing URLs\nlet existingUrls = [];\ntry {\n  const sheetData = $('Get Existing URLs').all();\n  existingUrls = sheetData.map(item => {\n    for (const val of Object.values(item.json)) {\n      const s = (val || '').toString().trim();\n      if (s.startsWith('http')) {\n        return s.toLowerCase();\n      }\n    }\n    return '';\n  }).filter(u => u.length > 0);\n} catch (e) {\n  existingUrls = [];\n}\n\nconst existingSet = new Set(existingUrls);\nconst urlBlockRegex = /<url>([\\s\\S]*?)<\\/url>/g;\nlet match;\nconst results = [];\nconst alreadyAdded = new Set();\n\nconst dateLimit = new Date(\"2026-01-01T00:00:00Z\");\n\nwhile ((match = urlBlockRegex.exec(sitemap)) !== null) {\n  const block = match[1];\n  const locMatch = block.match(/<loc>([^<]+)<\\/loc>/);\n  const lastmodMatch = block.match(/<lastmod>([^<]+)<\\/lastmod>/);\n  \n  if (locMatch) {\n    const url = locMatch[1];\n    const lastmod = lastmodMatch ? lastmodMatch[1] : null;\n    \n    if (url.toLowerCase().includes('durres') && url.includes('/property/')) {\n      const normalizedUrl = url.toString().trim().toLowerCase();\n      \n      if (!existingSet.has(normalizedUrl) && !alreadyAdded.has(normalizedUrl)) {\n        let isRecent = true;\n        if (lastmod) {\n          const modDate = new Date(lastmod);\n          isRecent = modDate >= dateLimit;\n        }\n        if (isRecent) {\n          results.push({ url, lastmod });\n          alreadyAdded.add(normalizedUrl);\n        }\n      }\n    }\n  }\n}\n\nreturn results.map(r => ({ json: r }));"
      },
