    {
      "parameters": {
        "jsCode": "const htmlData = $input.first().json;\n\nconst getFirst = (val) => {\n  if (Array.isArray(val)) return val[0] || '';\n  return val || '';\n};\n\nconst title = getFirst(htmlData.title).trim();\nconst price = getFirst(htmlData.price).trim();\nconst description = getFirst(htmlData.description).trim();\nconst agentPhoneLink = getFirst(htmlData.agent_phone);\nconst agentNameLink = getFirst(htmlData.agent_name_link);\n\n// 1. Очищуємо телефон агента\nconst agentPhone = agentPhoneLink ? agentPhoneLink.replace('tel:', '').trim() : '';\n\n// 2. Витягуємо ім'я агента з посилання\nlet agentName = '';\nif (agentNameLink) {\n  const parts = agentNameLink.split('/');\n  const lastPart = parts[parts.length - 1];\n  const namePart = lastPart.replace('.html', '').replace(/^\\d+-/, '');\n  agentName = namePart.split('-').map(word => word.charAt(0).toUpperCase() + word.slice(1)).join(' ');\n}\n\n// 3. Парсимо характеристики\nconst facilities = htmlData.facilities || [];\nlet area = '';\nlet bedrooms = '';\nlet category = 'Sale';\n\n// ВИПРАВЛЕНИЙ КОД: надійний пошук URL з ланцюжком fallback\nlet url = '';\ntry {\n  url = $('Wait 1s').item.json.url || $('Split In Batches').item.json.url || '';\n} catch (e) {\n  try {\n    url = $('Split In Batches').item.json.url || '';\n  } catch (err) {\n    url = '';\n  }\n}\n\nif (url.toLowerCase().includes('qera') || url.toLowerCase().includes('qira') || url.toLowerCase().includes('rent')) {\n  category = 'Rent';\n}\n\nfacilities.forEach(f => {\n  const text = f.toLowerCase();\n  if (text.includes('m2') || text.includes('sip.') || text.includes('surface')) {\n    const cleanText = text.replace(/m2/g, '').replace(/m²/g, '');\n    area = cleanText.replace(/[^0-9]/g, '').trim() + ' m2';\n  }\n  if (text.includes('bedroom') || text.includes('dhomat') || text.includes('bed')) {\n    bedrooms = f.replace(/[^0-9]/g, '').trim();\n  }\n});\n\nreturn {\n  url,\n  title,\n  price,\n  category,\n  area,\n  bedrooms,\n  description,\n  agentName,\n  agentPhone,\n  lastModified: new Date().toISOString()\n};"
      },
