    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// DOCX — це насправді ZIP-архів. Щоб нода Compression його розпакувала,\n// перейменовуємо бінарне вкладення на .zip (змінюємо лише метадані,\n// самі байти файлу не чіпаємо).\nconst item = $input.item;\nconst bin = item.binary && item.binary.data;\nif (bin) {\n  const base = (bin.fileName || \"file\").replace(/\\.[^.]+$/, \"\");\n  bin.fileName = base + \".zip\";\n  bin.fileExtension = \"zip\";\n  bin.mimeType = \"application/zip\";\n}\nreturn item;"
      },
      "id": "66acc6a7-7a0f-4085-90ec-ed54ec6d477e",
      "name": "Rename to Zip",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        672,
        192
      ]
    },
    {
      "parameters": {},
      "id": "937e9f03-65c3-4716-9ad8-5ea147cc0432",
      "name": "Decompress Docx",
      "type": "n8n-nodes-base.compression",
      "typeVersion": 1.1,
      "position": [
        896,
        192
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// Розпакований DOCX містить багато файлів (file_0, file_1, ...).\n// Текст резюме лежить у word/document.xml — знаходимо саме його\n// і віддаємо далі як бінарне поле \"data\".\nconst item = $input.item;\nconst binary = item.binary || {};\nlet picked = null;\nfor (const key of Object.keys(binary)) {\n  const f = binary[key];\n  const name = f.fileName || \"\";\n  const isDoc = name === \"word/document.xml\" || name.endsWith(\"/document.xml\") || name === \"document.xml\";\n  if (isDoc && !name.includes(\".rels\")) { picked = f; break; }\n}\nif (!picked) throw new Error(\"document.xml не знайдено у розпакованому DOCX\");\nreturn { json: { picked: \"word/document.xml\" }, binary: { data: picked } };"
      },
      "id": "828e9f4b-baee-4100-a08a-bf7e93855a6a",
      "name": "Pick document.xml",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1120,
        192
      ]
    },
    {
      "parameters": {
        "operation": "xml",
        "options": {}
      },
      "id": "3efa919a-32c8-4705-9fb5-b98c9245f861",
      "name": "Extract Docx XML",
      "type": "n8n-nodes-base.extractFromFile",
      "typeVersion": 1.1,
      "position": [
        1344,
        192
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "// УВАГА (для студентів): у цій версії n8n нода Extract from File (XML)\n// віддає СИРИЙ XML-РЯДОК у json.data, а не готовий обʼєкт.\n// Тому текст резюме дістаємо прямо з тегів <w:t>, а абзаци беремо з <w:p>.\nconst raw = $input.item.json.data;\nfunction stripDecode(s) {\n  return s.replace(/<[^>]+>/g, \"\")\n    .replace(/&amp;/g, \"&\").replace(/&lt;/g, \"<\").replace(/&gt;/g, \">\")\n    .replace(/&quot;/g, String.fromCharCode(34)).replace(/&apos;/g, String.fromCharCode(39))\n    .replace(/&#(\\d+);/g, (m, n) => String.fromCharCode(parseInt(n, 10)));\n}\nfunction fromXmlString(xml) {\n  const paras = xml.split(/<\\/w:p>/);\n  const lines = [];\n  for (const p of paras) {\n    const ts = p.match(/<w:t[^>]*>[\\s\\S]*?<\\/w:t>/g) || [];\n    if (!ts.length) continue;\n    const line = ts.map((t) => stripDecode(t)).join(\"\");\n    if (line.trim()) lines.push(line.trim());\n  }\n  return lines.join(\"\\n\");\n}\nlet cvText = \"\";\nif (typeof raw === \"string\") {\n  cvText = fromXmlString(raw);\n} else if (raw && typeof raw === \"object\") {\n  // запасний варіант: якщо XML колись прийде вже обʼєктом — зберемо всі w:t\n  const texts = [];\n  const visit = (v) => {\n    if (v === null || v === undefined) return;\n    if (Array.isArray(v)) { v.forEach(visit); return; }\n    if (typeof v === \"object\") {\n      for (const [k, val] of Object.entries(v)) {\n        const local = k.includes(\":\") ? k.split(\":\").pop() : k;\n        if (local === \"t\") texts.push(typeof val === \"string\" ? val : ((val && (val[\"#text\"] || val[\"_\"])) || \"\"));\n        else visit(val);\n      }\n    }\n  };\n  visit(raw);\n  cvText = texts.join(\" \").replace(/\\s+/g, \" \").trim();\n}\nreturn { json: { cvText } };"
      },
