    {
      "parameters": {
        "jsCode": "// Gmail кладе ВСІ вкладення в ОДИН елемент (item) під бінарними ключами\n// attachment_0, attachment_1, attachment_2 ...\n// Тут ми розкладаємо їх на ОКРЕМІ items — по одному файлу в кожному,\n// щоб далі Switch міг обробити кожен файл незалежно.\n// Режим \"Run Once for All Items\" — бо тільки він дозволяє повернути\n// БІЛЬШЕ елементів, ніж прийшло на вхід (1 лист -> N файлів).\nconst results = [];\nfor (const item of $input.all()) {\n  const binary = item.binary || {};\n  for (const key of Object.keys(binary)) {\n    const file = binary[key];\n    const fileName = file.fileName || \"\";\n    let ext = file.fileExtension || \"\";\n    if (!ext && fileName.includes(\".\")) ext = fileName.split(\".\").pop();\n    ext = String(ext).toLowerCase();\n    results.push({\n      json: { fileName, fileExtension: ext, mimeType: file.mimeType || \"\", sourceProperty: key },\n      binary: { data: file },\n    });\n  }\n}\nreturn results;"
      },
