        "jsCode": "const cb = $input.first().json.callback_query;\nconst text = cb.message.text || '';\n\nlet actualPost = text;\nif (text.includes('**Текст:**')) {\n  actualPost = text.split('**Текст:**')[1];\n}\nif (actualPost.includes('*Выберите действие:*')) {\n  actualPost = actualPost.split('*Выберите действие:*')[0];\n}\nactualPost = actualPost.trim();\n\nreturn [{\n  json: {\n    text: actualPost,\n    chatId: cb.message.chat.id,\n    messageId: cb.message.message_id,\n    callbackQueryId: cb.id\n  }\n}];"
