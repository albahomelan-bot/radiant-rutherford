        "jsCode": "let sourceLanguage = 'en';\nlet url = 'https://www.reddit.com/r/saas/hot.rss';\n\ntry {\n  if ($node['Schedule Trigger (Local)']) {\n    sourceLanguage = 'local';\n    url = 'https://dou.ua/feed/';\n  }\n} catch (e) {\n}\n\nreturn [{\n  json: {\n    url: url,\n    sourceLanguage: sourceLanguage\n  }\n}];"
