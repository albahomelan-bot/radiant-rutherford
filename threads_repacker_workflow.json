    {
      "parameters": {
        "jsCode": "const xmlData = $input.first().json;\nlet items = [];\n\nif (xmlData.rss && xmlData.rss.channel && xmlData.rss.channel.item) {\n  items = Array.isArray(xmlData.rss.channel.item) ? xmlData.rss.channel.item : [xmlData.rss.channel.item];\n} else if (xmlData.feed && xmlData.feed.entry) {\n  items = Array.isArray(xmlData.feed.entry) ? xmlData.feed.entry : [xmlData.feed.entry];\n}\n\nif (!items.length) {\n  return [{\n    json: {\n      title: 'Нет новых постов',\n      content: 'Не удалось распарсить RSS/Atom ленту.',\n      sourceLanguage: 'en'\n    }\n  }];\n}\n\nconst limit = Math.min(items.length, 5);\nconst randomIndex = Math.floor(Math.random() * limit);\nconst selectedItem = items[randomIndex];\n\nlet title = '';\nif (typeof selectedItem.title === 'string') {\n  title = selectedItem.title;\n} else if (selectedItem.title && selectedItem.title._value) {\n  title = selectedItem.title._value;\n} else if (selectedItem.title && selectedItem.title.$) {\n  title = selectedItem.title.$;\n}\n\nlet rawContent = '';\nconst contentSource = selectedItem.content || selectedItem.summary || selectedItem.description || '';\nif (typeof contentSource === 'string') {\n  rawContent = contentSource;\n} else if (contentSource._value) {\n  rawContent = contentSource._value;\n} else if (contentSource.$) {\n  rawContent = contentSource.$;\n}\n\nlet cleanContent = rawContent.replace(/<[^>]*>/g, ' ').replace(/\\s+/g, ' ').trim();\n\nif (cleanContent.includes('submitted by')) {\n  cleanContent = cleanContent.split('submitted by')[0].trim();\n}\n\nconst sourceLanguage = $('Determine Feed URL').item.json.sourceLanguage;\n\nreturn [{\n  json: {\n    title: title || 'Без заголовка',\n    content: cleanContent || 'Без содержимого',\n    sourceLanguage: sourceLanguage\n  }\n}];"
      },
