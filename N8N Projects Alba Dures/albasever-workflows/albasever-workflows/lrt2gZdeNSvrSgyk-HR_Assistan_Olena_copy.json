    {
      "parameters": {
        "jsCode": "const items = $input.all();\nconst parsedItems = items.map((item) => {\n  const parsedOutput = JSON.parse(item?.json?.output);\n  const stringifiedOutput = Object.keys(parsedOutput).reduce((acc, key) => {\n    acc[key] = String(parsedOutput[key]);\n    return acc;\n  }, {});\n  return { json: stringifiedOutput };\n});\nreturn parsedItems;\n"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        848,
        32
      ],
      "id": "42af500d-527c-4fab-9475-7dcf10dd0fb3",
      "name": "Parse Json"
    },
    {
      "parameters": {
        "jsCode": "const rows = $input.all().map((item) => item.json);\nconst candidates = $(\"Parse Json\").all().map((item) => item.json);\n\nconst updatedCandidates = candidates.map((candidate) => {\n  // 1. Приводим email кандидата к нижнему регистру и убираем случайные пробелы\n  const candidateEmail = candidate.email ? candidate.email.toLowerCase().trim() : '';\n\n  // 2. Ищем, была ли уже строка с таким email в таблице ( rows )\n  const matchingRow = rows.find(row => {\n    const rowEmail = row.Email ? row.Email.toLowerCase().trim() : '';\n    return rowEmail === candidateEmail && candidateEmail !== '';\n  });\n  \n  // 3. Если строка нашлась, узнаем её текущий статус из таблицы\n  const currentStatus = matchingRow ? matchingRow.Status : undefined;\n\n  // 4. ЗАЩИТА РУЧНЫХ ИЗМЕНЕНИЙ: Если статус изменен человеком (НЕ \"new\" и НЕ \"duplicate\") — возвращаем его без изменений\n  if (currentStatus && currentStatus !== \"new\" && currentStatus !== \"duplicate\") {\n    return { ...candidate, Status: currentStatus };\n  }\n\n  // 5. ИСПРАВЛЕННАЯ ЛОГИКА ДУБЛИКАТОВ: \n  // Если matchingRow нашлась в таблице — значит, этот email уже присылали ранее -> \"duplicate\".\n  // Если matchingRow НЕ нашлась в таблице — значит, это абсолютно новый кандидат -> \"new\".\n  const newStatus = matchingRow ? \"duplicate\" : \"new\";\n  \n  return { ...candidate, Status: newStatus };\n});\n\n// Возвращаем результат в правильном формате для n8n\nreturn updatedCandidates.map((candidate) => ({ json: candidate }));"
      },
