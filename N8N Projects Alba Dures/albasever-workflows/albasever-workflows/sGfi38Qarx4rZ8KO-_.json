    {
      "parameters": {
        "jsCode": "// 1. Беремо сирі вхідні дані від ноди Analyze an image1\nconst inputItems = $input.all();\nif (!inputItems || inputItems.length === 0) {\n  throw new Error(\"Вхідні дані порожні!\");\n}\n\nconst inputData = inputItems[0].json;\n\n// 2. Витягуємо сирий текст відповіді ШІ\nlet rawText = \"\";\nif (inputData.candidates?.[0]?.content?.parts?.[0]?.text) {\n  rawText = inputData.candidates[0].content.parts[0].text;\n} else if (typeof inputData.text === 'string') {\n  rawText = inputData.text;\n} else {\n  rawText = JSON.stringify(inputData);\n}\n\nrawText = String(rawText).trim();\n\n// 3. Зачищаємо markdown-маркери, якщо вони є\nlet cleanText = rawText.replace(/```json/g, \"\").replace(/```/g, \"\").trim();\n\n// Захист від сміття в кінці рядка (шукаємо останню закриваючу фігурну дужку структури JSON)\nconst lastBraceIndex = cleanText.lastIndexOf('}');\nif (lastBraceIndex !== -1) {\n  cleanText = cleanText.substring(0, lastBraceIndex + 1);\n}\n\n// 4. Перетворюємо рядок у реальний об'єкт JSON\nlet cleanJson;\ntry {\n  cleanJson = JSON.parse(cleanText);\n} catch (e) {\n  throw new Error(\"Не вдалося розпарсити текст чека у JSON. Сирий текст: \" + cleanText);\n}\n\n// 5. Гнучкий пошук масиву товарів (підтримка англійських та кириличних ключів ШІ)\nconst itemsArray = cleanJson.items || cleanJson.goods || cleanJson.products || cleanJson[\"покупки\"] || cleanJson[\"товары\"] || [];\n\n// Гнучкий пошук дати чека\nconst storeInfo = cleanJson.store_info || cleanJson[\"магазин\"] || {};\nconst dateBill = storeInfo.date_time || storeInfo[\"дата\"] || \"30.06.2026\";\n\nif (itemsArray.length === 0) {\n  throw new Error(\"Масив товарів порожній! Перевір структуру: \" + JSON.stringify(cleanJson));\n}\n\n// 6. Формуємо плоску структуру ітемів для Google Sheets з мапінгом усіх варіантів полів\nreturn itemsArray.map(item => {\n  // Шукаємо назву товару (пріоритет перекладу на російську/українську, потім оригінал)\n  const productName = item.item_name_ukrainian || item.item_name_russian || item[\"перевод_русский\"] || item[\"перевод_украинский\"] || item.item_name_albanian || item[\"наименование_албанский\"] || item.product || item.name || \"Невідомий товар\";\n  \n  // Шукаємо кількість / вагу\n  const quantity = parseFloat(item.quantity_weight) || parseFloat(item.quantity) || parseFloat(item[\"количество\"]) || parseFloat(item.amount) || 1;\n  \n  // Шукаємо ціну за одиницю\n  const priceAll = parseFloat(item.unit_price_all) || parseFloat(item[\"цена_за_единицу_ALL\"]) || parseFloat(item.price) || 0;\n  \n  // Шукаємо фінальну суму за позицію в леках (якщо немає — рахуємо автоматично)\n  const totalAll = parseFloat(item.total_price_all) || parseFloat(item[\"итого_ALL\"]) || parseFloat(item.total) || (quantity * priceAll);\n  \n  // Фінансова математика за ТЗ\n  const totalUah = parseFloat((totalAll * 0.55).toFixed(2)); // Курс 0.55 UAH за 1 ALL\n  const totalEur = parseFloat((totalAll / 94).toFixed(2));   // Курс 94 ALL за 1 EUR\n\n  return {\n    json: {\n      date: dateBill,\n      source_type: \"Чек\",\n      product: productName,\n      quantity: quantity,\n      price_all: priceAll,\n      total_all: totalAll,\n      total_uah: totalUah,\n      total_eur: totalEur\n    }\n  };\n});"
      },
